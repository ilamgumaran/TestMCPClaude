# Required: Home Depot Product API key
HD_API_KEY=your_hd_api_key_here

# Optional: override default API base URL
HD_API_BASE_URL=https://productapi.homedepot.com

# Optional: default store ID for inventory lookups
HD_DEFAULT_STORE_ID=

# Required for get_project_products tool
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: HTTP request timeout in seconds (default: 30)
HD_REQUEST_TIMEOUT=30
